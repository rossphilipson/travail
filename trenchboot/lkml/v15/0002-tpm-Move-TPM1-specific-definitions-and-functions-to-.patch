 drivers/char/tpm/tpm1-cmd.c     |  5 --
 drivers/char/tpm/tpm1_structs.h | 97 ++++++++++++++++++++++++++++++++
 include/linux/tpm1.h            | 34 +++++++++++-
 4 files changed, 132 insertions(+), 102 deletions(-)
 create mode 100644 drivers/char/tpm/tpm1_structs.h

